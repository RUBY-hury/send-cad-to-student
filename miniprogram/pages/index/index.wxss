.container {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 40rpx 30rpx;
    min-height: 100vh;
    box-sizing: border-box;
}

.header { text-align: center; margin-bottom: 30rpx; }

.title {
    display: block;
    font-size: 48rpx;
    font-weight: bold;
    color: #f0c040;
    text-shadow: 0 2rpx 12rpx rgba(240, 192, 64, 0.4);
    margin-bottom: 12rpx;
}

.subtitle { display: block; font-size: 26rpx; color: #8892b0; }

.main-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
}

.wheel-container {
    position: relative;
    width: 520rpx;
    height: 520rpx;
    margin-bottom: 40rpx;
}

.wheel-canvas { width: 520rpx; height: 520rpx; }

.pointer {
    position: absolute;
    top: -10rpx;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 20rpx solid transparent;
    border-right: 20rpx solid transparent;
    border-top: 40rpx solid #ff4757;
    z-index: 10;
    filter: drop-shadow(0 2rpx 4rpx rgba(0,0,0,0.5));
}

.result-circle {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 160rpx;
    height: 160rpx;
    border-radius: 50%;
    background: rgba(26, 26, 46, 0.95);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border: 4rpx solid #f0c040;
    box-shadow: 0 0 30rpx rgba(240, 192, 64, 0.3);
}

.result-number {
    font-size: 56rpx;
    font-weight: bold;
    color: #f0c040;
    line-height: 60rpx;
}
.result-label { font-size: 22rpx; color: #8892b0; margin-top: 4rpx; }

.form-section {
    width: 100%;
    max-width: 600rpx;
    background: rgba(255,255,255,0.06);
    border-radius: 20rpx;
    padding: 30rpx;
    box-sizing: border-box;
}

.form-item {
    display: flex;
    align-items: center;
    margin-bottom: 24rpx;
}

.form-item:last-child { margin-bottom: 0; }

.form-label {
    width: 80rpx;
    font-size: 28rpx;
    color: #ccd6f6;
    flex-shrink: 0;
}

.form-input {
    flex: 1;
    height: 70rpx;
    background: rgba(255,255,255,0.1);
    border-radius: 12rpx;
    padding: 0 20rpx;
    font-size: 28rpx;
    color: #fff;
    border: 2rpx solid rgba(255,255,255,0.12);
}

.form-input:focus { border-color: #f0c040; }
.form-placeholder { color: rgba(255,255,255,0.3); }

.action-section { margin: 30rpx 0; }

.spin-btn {
    width: 480rpx;
    height: 90rpx;
    background: linear-gradient(135deg, #f0c040, #e0a800);
    color: #1a1a2e;
    font-size: 34rpx;
    font-weight: bold;
    border-radius: 45rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    box-shadow: 0 6rpx 20rpx rgba(240, 192, 64, 0.35);
    transition: all 0.2s;
}

.spin-btn:active { transform: scale(0.96); opacity: 0.85; }

.spin-btn.disabled {
    background: linear-gradient(135deg, #555, #444);
    color: #888;
    box-shadow: none;
}

.status-section {
    width: 100%;
    max-width: 600rpx;
    margin-bottom: 30rpx;
}

.status {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12rpx;
    padding: 24rpx;
    border-radius: 16rpx;
    font-size: 28rpx;
}

.status.success { background: rgba(76, 175, 80, 0.2); color: #4caf50; border: 1rpx solid rgba(76, 175, 80, 0.3); }
.status.error { background: rgba(244, 67, 54, 0.2); color: #f44336; border: 1rpx solid rgba(244, 67, 54, 0.3); }
.status.info { background: rgba(33, 150, 243, 0.2); color: #2196f3; border: 1rpx solid rgba(33, 150, 243, 0.3); }

.history-section {
    width: 100%;
    max-width: 600rpx;
    background: rgba(255,255,255,0.05);
    border-radius: 20rpx;
    padding: 24rpx;
    box-sizing: border-box;
}

.history-title {
    font-size: 30rpx;
    font-weight: bold;
    color: #ccd6f6;
    margin-bottom: 20rpx;
}

.history-list { max-height: 400rpx; }

.history-item {
    display: flex;
    align-items: center;
    gap: 16rpx;
    padding: 16rpx 0;
    border-bottom: 1rpx solid rgba(255,255,255,0.06);
    font-size: 24rpx;
}
.history-item:last-child { border-bottom: none; }

.hist-num { color: #f0c040; font-weight: bold; width: 100rpx; }
.hist-name { color: #ccd6f6; width: 100rpx; }
.hist-email { color: #8892b0; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.hist-status { width: 100rpx; text-align: right; }
.sent-ok { color: #4caf50; }
.sent-fail { color: #f44336; }
